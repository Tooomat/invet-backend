{
  "name": "invet-backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",

    "start:dev": "dotenv -e .env.development.local -- cross-env NODE_ENV=development nest start --watch",
    "start:dev:docker:up": "docker compose --env-file .env.development.docker -f docker-compose.dev.yml up -d --build",
    "start:dev:docker:start": "docker compose --env-file .env.development.docker -f docker-compose.dev.yml start",
    "start:dev:docker:stop": "docker compose --env-file .env.development.docker -f docker-compose.dev.yml stop",
    "start:dev:docker:down": "docker compose --env-file .env.development.docker -f docker-compose.dev.yml down",
    "start:dev:docker:down:volume": "docker compose --env-file .env.development.docker -f docker-compose.dev.yml down -v",

    "start:debug": "dotenv -e .env.development.local -- cross-env NODE_ENV=development nest start --debug --watch",
    "start:prod": "dotenv -e .env -- cross-env NODE_ENV=production node dist/main",

    "test": "dotenv -e .env.test.local -- cross-env NODE_ENV=test jest --runInBand",
    "test:watch": "dotenv -e .env.test.local -- cross-env NODE_ENV=test jest --watch",
    "test:cov": "dotenv -e .env.test.local -- cross-env NODE_ENV=test jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInpridBand",

    "prisma:generate:dev": "dotenv -e .env.development.local -- prisma generate",
    "prisma:generate:dev:docker": "docker exec -it server-invet-dev npx dotenv -e .env.development.docker -- prisma generate",

    "prisma:migrate:dev": "dotenv -e .env.development.local -- prisma migrate dev",
    "prisma:migrate:dev:docker": "docker exec -it server-invet-dev npx dotenv -e .env.development.docker -- prisma migrate dev",
    "prisma:migrate:test": "dotenv -e .env.test.local -- prisma migrate deploy",
    "prisma:migrate:prod": "dotenv -e .env -- prisma migrate deploy",

    "prisma:seed:dev": "dotenv -e .env.development.local -- ts-node prisma/seeds/index.seeds.ts",
    "prisma:seed:dev:docker": "docker exec -it server-invet-dev npx dotenv -e .env.development.docker -- ts-node prisma/seeds/index.seeds.ts",
    "prisma:seed:test": "dotenv -e .env.test.local -- ts-node prisma/seeds/index.seeds.ts",
    "prisma:seed:prod": "dotenv -e .env -- node dist/prisma/seeds/index.seeds.ts",

    "prisma:studio:dev": "dotenv -e .env.development.local -- prisma studio",
    "prisma:studio:test": "dotenv -e .env.test.local -- prisma studio --port 5556"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/swagger": "^11.4.4",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.4.2",
    "ioredis": "^5.11.1",
    "nestjs-pino": "^4.6.1",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "uuid": "^14.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.0",
    "@types/ioredis": "^4.28.10",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "prisma": "^7.8.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "test",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^src/(.*)$": "<rootDir>/../src/$1"
    },
    "modulePaths": [
      "<rootDir>/.."
    ]
  }
}
