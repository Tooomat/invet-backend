generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// =========================
// ENUMS
// =========================
enum Role {
  USER
  ADMIN
}

enum StatusUser {
  PENDING_VERIFICATION
  ACTIVE
  BLOCKED
}

enum StatusInvitation {
  DRAFTED
  PUBLISHED
  ARCHIVED
  EXPIRED
}

enum EventName {
  RESEPSI
  ACARA_PERNIKAHAN
}

enum Attendance {
  NOT_CHOOSING
  PRESENT
  NOT_PRESENT
}

enum CategoryGuest {
  FAMILY
  FRIEND
  OFFICE
  VIP
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum Packages {
  PACKAGE_A
  PACKAGE_B
  PACKAGE_C
}

enum TemplateTag {
  BASIC
  PREMIUM_1
  PREMIUM_2
  PREMIUM_3
}

// =========================
// USERS
// =========================
model User {
  id     String     @id @default(uuid())
  role   Role       @default(USER)
  status StatusUser @default(PENDING_VERIFICATION)

  firstName String  @map("first_name")
  lastName  String? @map("last_name")
  email     String  @unique
  phone     String? @unique @db.VarChar(20)
  password  String

  isEmailVerified Boolean   @default(false) @map("is_email_verified")
  emailVerifiedAt DateTime? @map("email_verified_at") @db.Timestamptz(3)

  lastLoginAt           DateTime? @map("last_login_at") @db.Timestamptz(3)
  lastPasswordChangedAt DateTime? @map("last_password_change_at") @db.Timestamptz(3)

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime? @updatedAt @map("updated_at") @db.Timestamptz(3)

  invitations             Invitation[]
  emailVerifications      EmailVerification[]
  changeEmailRequests     ChangeEmailRequest[]
  userSubscriptions       UserSubscription[]
  orders                  Order[]
  userCustomTemplates     UserCustomTemplate[] @relation("UserId")
  assignedCustomTemplates UserCustomTemplate[] @relation("AssignedBy")
  // systemSettings          SystemSetting[]

  @@map("users")
}

