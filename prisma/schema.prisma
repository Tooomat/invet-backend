// =========================
// EMAIL VERIFICATION
// =========================
model EmailVerification {
  id    String @id @default(uuid())
  token String @unique

  expiresAt DateTime  @map("expires_at") @db.Timestamptz(3)
  usedAt    DateTime? @map("used_at") @db.Timestamptz(3)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_verifications")
}

// =========================
// EMAIL CHANGE VERIFICATION
// =========================
model ChangeEmailRequest {
  id    String @id @default(uuid())
  token String @unique

  newEmail String @map("new_email")

  isEmailSent Boolean @default(false) @map("is_email_sent")

  expiresAt DateTime  @map("expires_at") @db.Timestamptz(3)
  usedAt    DateTime? @map("used_at") @db.Timestamptz(3)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_change_requests")
}

// =========================
// PACKAGES
// =========================
model Package {
  id           String   @id @default(uuid())
  name         Packages
  price        Decimal
  durationDays Int      @map("duration_days")

  // feature flags
  hasRsvp        Boolean @default(false) @map("has_rsvp")
  hasAnimation   Boolean @default(false) @map("has_animation")
  hasAutoWaBlast Boolean @default(false) @map("has_auto_wa_blast")
  maxGuests      Int     @default(0) @map("max_guests")
  maxInvitations Int     @default(1) @map("max_invitations")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime? @updatedAt @map("updated_at") @db.Timestamptz(3)

  accessibleTiers   PackageAccessibleTier[]
  userSubscriptions UserSubscription[]
  orders            Order[]

  @@map("packages")
}

// =========================
// PACKAGES ACCESSIBLE TIER
// =========================
model PackageAccessibleTier {
  id   String      @id @default(uuid())
  tier TemplateTag

  packageId String  @map("package_id")
  package   Package @relation(fields: [packageId], references: [id])

  @@unique([packageId, tier])
  @@map("package_accessible_tiers")
}

// =========================
// USER SUBCRIPTION
// =========================
model UserSubscription {
  id     String             @id @default(uuid())
  status SubscriptionStatus @default(ACTIVE)

  startedAt DateTime  @map("started_at") @db.Timestamptz(3)
  expiredAt DateTime? @map("expired_at") @db.Timestamptz(3)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime? @updatedAt @map("updated_at") @db.Timestamptz(3)

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id])

  packageId String  @map("package_id")
  package   Package @relation(fields: [packageId], references: [id])

  orders      Order[]
  invitations Invitation[]

  @@map("user_subscriptions")
}

// =========================
// ORDER
// =========================
model Order {
  id String @id @default(uuid())

  isCustom   Boolean @default(false) @map("is_custom")
  customNote String? @map("custom_note") @db.Text

  amount        Decimal
  status        OrderStatus @default(PENDING)
  paymentMethod String?     @map("payment_method")
  paymentRef    String?     @map("payment_ref")

  paidAt    DateTime? @map("paid_at") @db.Timestamptz(3)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime? @updatedAt @map("updated_at") @db.Timestamptz(3)

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id])

  packageId String  @map("package_id")
  package   Package @relation(fields: [packageId], references: [id])

  subscriptionId String?           @map("subscription_id")
  subscription   UserSubscription? @relation(fields: [subscriptionId], references: [id])

  @@map("orders")
}

// =========================
// USER CUSTOM TEMPLATES
// =========================
model UserCustomTemplate {
  id String @id @default(uuid())

  assignedAt DateTime @map("assigned_at") @db.Timestamptz(3)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  userId String @map("user_id")
  user   User   @relation("UserId", fields: [userId], references: [id])

  templateId String   @map("template_id")
  template   Template @relation(fields: [templateId], references: [id])

  assignedBy String? @map("assigned_by")
  admin      User?   @relation("AssignedBy", fields: [assignedBy], references: [id])

  @@map("user_custom_templates")
}

// =========================
// TEMPLATES
// =========================
model Template {
  id           String      @id @default(uuid())
  name         String
  slug         String      @unique
  musicUrl     String?     @map("music_url") @db.Text
  previewImage String?     @map("preview_image") @db.Text
  tag          TemplateTag @default(BASIC)

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime? @updatedAt @map("updated_at") @db.Timestamptz(3)

  invitations         Invitation[]
  userCustomTemplates UserCustomTemplate[]

  @@map("templates")
}

// =========================
// INVITATIONS
// =========================
model Invitation {
  id String @id @default(uuid())

  title  String
  slug   String           @unique
  status StatusInvitation @default(DRAFTED)

  customMusicUrl String? @map("custom_music_url") @db.Text
  preweddingUrl  String? @map("prewedding_url") @db.Text
  livestreamUrl  String? @map("livestream_url") @db.Text

  expiredAt DateTime? @map("expired_at") @db.Timestamptz(3)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime? @updatedAt @map("updated_at") @db.Timestamptz(3)

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id])

  templateId String   @map("template_id")
  template   Template @relation(fields: [templateId], references: [id])

  subscriptionId   String?           @map("subscription_id")
  userSubscription UserSubscription? @relation(fields: [userSubscriptionId], references: [id])

  couple             Couple? // one to one
  events             Event[]
  galleries          Gallery[]
  stories            OurStory[]
  guests             Guest[]
  gifts              Gift[]
  thankYou           ThankYou?
  userSubscriptionId String?

  @@map("invitations")
}

// =========================
// COUPLES
// =========================
model Couple {
  id           String @id @default(uuid())
  invitationId String @unique @map("invitation_id")

  heroImage String? @map("hero_image") @db.Text

  groomFullName String  @map("groom_full_name")
  groomNickname String  @map("groom_nickname")
  groomFather   String  @map("groom_father")
  groomMother   String  @map("groom_mother")
  groomPhoto    String? @map("groom_photo") @db.Text
  groomIgUrl    String? @map("groom_ig_url") @db.Text

  brideFullName String  @map("bride_full_name")
  brideNickname String  @map("bride_nickname")
  brideFather   String  @map("bride_father")
  brideMother   String  @map("bride_mother")
  bridePhoto    String? @map("bride_photo") @db.Text
  brideIgUrl    String? @map("bride_ig_url") @db.Text

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime? @updatedAt @map("updated_at") @db.Timestamptz(3)

  invitation Invitation @relation(fields: [invitationId], references: [id])

  @@map("couples")
}

// =========================
// EVENTS
// =========================
model Event {
  id           String @id @default(uuid())
  invitationId String @map("invitation_id")
  addressId    String @map("address_id")

  name      EventName
  eventDate DateTime  @map("event_date") @db.Date
  start     DateTime  @db.Timestamptz(3)
  end       DateTime? @db.Timestamptz(3)

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime? @updatedAt @map("updated_at") @db.Timestamptz(3)

  invitation Invitation @relation(fields: [invitationId], references: [id])
  address    Address    @relation(fields: [addressId], references: [id])

  @@unique([invitationId, name]) // nama event sama di invitation yang sama
  @@map("events")
}

// =========================
// ADDRESSES
// =========================
model Address {
  id            String @id @default(uuid())
  subdistrictId String @map("subdistrict_id")

  place      String
  street     String  @db.Text
  postalCode String  @map("postal_code") @db.VarChar(10)
  mapsUrl    String? @map("maps_url") @db.Text

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime? @updatedAt @map("updated_at") @db.Timestamptz(3)

  subdistrict MasterSubdistrict @relation(fields: [subdistrictId], references: [id])
  events      Event[]

  @@map("addresses")
}

// =========================
// MASTER WILAYAH
// =========================
model MasterProvince {
  id   String @id
  name String @db.VarChar(255)
  code String @unique @db.VarChar(20)

  cities MasterCity[]

  @@map("master_provinces")
}

model MasterCity {
  id         String @id
  provinceId String @map("province_id")

  name     String @db.VarChar(255)
  code     String @unique @db.VarChar(20)
  province Json

  province_rel MasterProvince   @relation(fields: [provinceId], references: [id])
  districts    MasterDistrict[]

  @@map("master_cities")
}

model MasterDistrict {
  id     String @id
  cityId String @map("city_id")

  name     String @db.VarChar(255)
  code     String @unique @db.VarChar(20)
  province Json
  city     Json

  city_rel     MasterCity          @relation(fields: [cityId], references: [id])
  subdistricts MasterSubdistrict[]

  @@map("master_districts")
}

model MasterSubdistrict {
  id         String @id
  districtId String @map("district_id")

  name     String @db.VarChar(255)
  code     String @unique @db.VarChar(20)
  province Json
  city     Json
  district Json

  district_rel MasterDistrict @relation(fields: [districtId], references: [id])
  addresses    Address[]

  @@map("master_subdistricts")
}

// =========================
// GALLERIES
// =========================
model Gallery {
  id           String @id @default(uuid())
  invitationId String @map("invitation_id")

  imageUrl  String @map("image_url") @db.Text
  sortOrder Int    @default(0) @map("sort_order")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime? @updatedAt @map("updated_at") @db.Timestamptz(3)

  invitation Invitation @relation(fields: [invitationId], references: [id])

  @@unique([invitationId, imageUrl]) // gambar sama di invitation yang sama
  @@map("galleries")
}

// =========================
// OUR STORIES
// =========================
model OurStory {
  id           String @id @default(uuid())
  invitationId String @map("invitation_id")

  title       String
  description String    @db.Text
  storyDate   DateTime? @map("story_date") @db.Date

  imageUrl1 String? @map("image_url1") @db.Text
  imageUrl2 String? @map("image_url2") @db.Text
  imageUrl3 String? @map("image_url3") @db.Text

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime? @updatedAt @map("updated_at") @db.Timestamptz(3)

  invitation Invitation @relation(fields: [invitationId], references: [id])

  @@unique([invitationId, title]) // judul sama di invitation yang sama
  @@map("our_stories")
}

// =========================
// GUESTS
// =========================
model Guest {
  id           String @id @default(uuid())
  invitationId String @map("invitation_id")

  name     String
  phone    String        @unique @db.VarChar(20)
  category CategoryGuest

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime? @updatedAt @map("updated_at") @db.Timestamptz(3)

  invitation Invitation @relation(fields: [invitationId], references: [id])
  rsvp       Rsvp?

  @@map("guests")
}

// =========================
// RSVP
// =========================
model Rsvp {
  id      String @id @default(uuid())
  guestId String @unique @map("guest_id")

  attendance Attendance @default(NOT_CHOOSING)
  totalGuest Int        @default(1) @map("total_guest")
  message    String?    @db.Text

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime? @updatedAt @map("updated_at") @db.Timestamptz(3)

  guest Guest @relation(fields: [guestId], references: [id])

  @@map("rsvps")
}

// =========================
// GIFTS
// =========================
model Gift {
  id           String @id @default(uuid())
  invitationId String @map("invitation_id")

  bankName      String @map("bank_name")
  accountNumber String @unique @map("account_number")
  accountHolder String @map("account_holder")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime? @updatedAt @map("updated_at") @db.Timestamptz(3)

  invitation Invitation @relation(fields: [invitationId], references: [id])

  @@map("gifts")
}

// =========================
// THANK YOU
// =========================
model ThankYou {
  id           String @id @default(uuid())
  invitationId String @unique @map("invitation_id")

  imageUrl String? @map("image_url") @db.Text
  message  String? @db.Text

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime? @updatedAt @map("updated_at") @db.Timestamptz(3)

  invitation Invitation @relation(fields: [invitationId], references: [id])

  @@map("thank_you")
}
