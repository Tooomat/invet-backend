# =====================
# APP CONFIG
# =====================
NODE_ENV=test
APP_NAME=invet
APP_V=1.0
APP_PORT=3001
APP_URL=http://localhost:3001

# =====================
# DATABASE POSTGRE (DB terpisah khusus test)
# =====================
DATABASE_URL="postgresql://postgres:1234@localhost:5432/invet_test?schema=public&connection_limit=5&pool_timeout=10"
DB_HOST=localhost
DB_USER=postgres
DB_PORT=5432
DB_PASSWORD=1234
DB_NAME=dot_test

# =====================
# JWT
# ACCESS + REFRESH
# =====================
JWT_REFRESH_SECRET=test-refresh-secret
JWT_REFRESH_EXPIRE=7d
JWT_ACCESS_SECRET=test-access-secret
JWT_ACCESS_EXPIRE=1h

# =====================
# LOGGING
# =====================
LOG_LEVEL=debug

# =====================
# Cookies
# =====================
HTTPONLY_COOKIES=true
SECURE_COOKIES=false
SAMESITE_COOKIES=lax

# =====================
# CORS
# =====================
CORS_ORIGIN=http://localhost:3001

# =====================
# REDIS
# =====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=1

# =====================
# CLOUDINARY
# =====================
CLOUDINARY_CLOUD_NAME=xxxxxxx
CLOUDINARY_API_KEY=xxxxxxx
CLOUDINARY_API_SECRET=xxxxxxx

# =====================
# RESEND
# =====================
RESEND_API_KEY=re_xxxxxxxx
EMAIL_FROM=onboarding@resend.dev